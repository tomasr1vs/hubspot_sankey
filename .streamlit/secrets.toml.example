# Streamlit secrets template. For local dev only — Streamlit Cloud has its
# own Secrets UI in the app settings page.
#
# 1. Copy this file to `.streamlit/secrets.toml` (which is gitignored).
# 2. Paste your real HubSpot Private App token between the quotes.
# 3. Restart `streamlit run app.py`.
HUBSPOT_PRIVATE_APP_TOKEN = "pat-na1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
